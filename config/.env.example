# EcoDominicano source - today's top article for distribution
TODAY_TOP_URL=https://ecodominicano.com/api/distribution/today-top
STATE_DB_PATH=/opt/ecodominicano-distributor/data/distributor.db
TIMEZONE=America/Santo_Domingo

# Reddit (OAuth2 — see docs/REDDIT_SETUP.md)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
# Reddit username (for User-Agent: web:EcoDominicano-Distributor:v1.0 (by /u/YOU))
REDDIT_USERNAME=FriendlyDominican
# Must match Reddit app "redirect uri" exactly when using npm run reddit:token
REDDIT_REDIRECT_URI=http://localhost:8080
# Optional full User-Agent string (must identify app + Reddit user per Reddit API rules)
# REDDIT_USER_AGENT=web:EcoDominicano-Distributor:v1.0 (by /u/YourUser)
REDDIT_SUBREDDIT=              # live subreddit (no r/ prefix)
REDDIT_SUBREDDIT_TEST=        # test sub you moderate (--test uses this only)
REDDIT_DAILY_LIMIT=5
REDDIT_DAILY_YELLOW=4
# Set to 0 to use raw article title (skip Ollama)
REDDIT_USE_OLLAMA=1

# Telegram — Bot API (channel posting)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=          # numeric channel ID (e.g. -1003809315976 for @Ecodominicano)
TELEGRAM_GROUP_IDS=           # comma-separated group IDs (e.g. -5040327611,-1009876543210)

# Telegram — GramJS user account (groups where the bot is NOT admin)
# After setting api_id/hash/phone, run once: npm run telegram:login (OTP on phone)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=               # your phone number with country code, e.g. +13476150920
TG_SESSION_PATH=/opt/ecodominicano-distributor/state/telegram-session.txt

# GramJS (member-only groups) daily cap — bot channel/admin posts are unlimited by this cap
# Phase 1: TELEGRAM_GRAMJS_CAP_PHASE1 for TELEGRAM_RAMP_DAYS from TELEGRAM_RAMP_START_DATE (YYYY-MM-DD, DR calendar)
# Phase 2: TELEGRAM_GRAMJS_CAP_PHASE2 after that (e.g. 15 → 30 after 20 days)
TELEGRAM_RAMP_START_DATE=2026-03-19
TELEGRAM_RAMP_DAYS=20
TELEGRAM_GRAMJS_CAP_PHASE1=15
TELEGRAM_GRAMJS_CAP_PHASE2=30
# Optional override for yellow indicator (else ~87% of current cap)
# TELEGRAM_GRAMJS_YELLOW_AT=13
TELEGRAM_INTER_DELAY_MIN=2000
TELEGRAM_INTER_DELAY_MAX=4000
# Test distribution: group/channel ID only (no DMs). If unset, uses first Bot API target.
TELEGRAM_TEST_GROUP_ID=
# Set to 0 to skip fetching og:image (faster; relies on link preview only)
TELEGRAM_FETCH_OG_IMAGE=1

# Facebook - browser automation (use with caution)
# FB_EMAIL=
# FB_PASSWORD=

# WhatsApp Web - browser automation (groups auto-detected from chat list)
WA_SESSION_PATH=/opt/ecodominicano-distributor/state/browser-sessions/whatsapp
# Top-5 groups by recent activity are auto-selected; no member count needed
# Comma-separated group names to exclude from auto-detection
# WA_GROUP_BLOCKLIST=Group1,Group2
# Official WhatsApp Channel name (exact match) — post is also sent here
WA_CHANNEL_NAME=EcoDominicano | Noticias RD
# Daily group send limits: green < 20, yellow 20-24, red = 25
WA_DAILY_LIMIT=25
WA_DAILY_YELLOW=20
# Your own WhatsApp number for test distribution (receives "Probando..." instead of real groups)
WA_TEST_PHONE=+13476150920
# Link preview delay: 3-5 seconds after pasting (ms)
WA_LINK_PREVIEW_MIN=7000
WA_LINK_PREVIEW_MAX=10000
# Anti-ban jitter: 300-600 seconds between messages
WA_INTER_MESSAGE_DELAY_MIN=300
WA_INTER_MESSAGE_DELAY_MAX=600
# Chat list load timeout (seconds) - increase for accounts with many groups
WA_CHAT_LOAD_TIMEOUT=600

# Ollama (runs on host; VM connects via 10.0.2.2 for VirtualBox NAT)
# Ensure Ollama listens: set OLLAMA_HOST=0.0.0.0 on host, or use bridged networking
OLLAMA_URL=http://10.0.2.2:11434
OLLAMA_MODEL=llama3.1:8b
