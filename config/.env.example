# EcoDominicano source - today's top article for distribution
TODAY_TOP_URL=https://ecodominicano.com/api/distribution/today-top
STATE_DB_PATH=/opt/ecodominicano-distributor/data/distributor.db
TIMEZONE=America/Santo_Domingo

# Reddit (OAuth2 - use refresh token)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_SUBREDDIT=

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Facebook - browser automation (use with caution)
# FB_EMAIL=
# FB_PASSWORD=

# WhatsApp Web - browser automation (groups auto-detected from chat list)
WA_SESSION_PATH=/opt/ecodominicano-distributor/state/browser-sessions/whatsapp
# Top-5 groups by recent activity are auto-selected; no member count needed
# Comma-separated group names to exclude from auto-detection
# WA_GROUP_BLOCKLIST=Group1,Group2
# Official WhatsApp Channel name (exact match) — post is also sent here
WA_CHANNEL_NAME=EcoDominicano | Noticias RD
# Your own WhatsApp number for test distribution (receives "Probando..." instead of real groups)
WA_TEST_PHONE=+13476150920
# Link preview delay: 3-5 seconds after pasting (ms)
WA_LINK_PREVIEW_MIN=3000
WA_LINK_PREVIEW_MAX=5000
# Anti-ban jitter: 300-600 seconds between messages
WA_INTER_MESSAGE_DELAY_MIN=300
WA_INTER_MESSAGE_DELAY_MAX=600
# Chat list load timeout (seconds) - increase for accounts with many groups
WA_CHAT_LOAD_TIMEOUT=600

# Ollama (runs on host; VM connects via 10.0.2.2 for VirtualBox NAT)
# Ensure Ollama listens: set OLLAMA_HOST=0.0.0.0 on host, or use bridged networking
OLLAMA_URL=http://10.0.2.2:11434
OLLAMA_MODEL=llama3.1:8b
